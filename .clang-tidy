---
# Curated, pragmatic check set. Magic-number and array-index checks are disabled
# because dense FEM math (b_i, c_i coefficients, quadrature weights, ...) makes
# them noisy without adding value.
Checks: >
  -*,
  bugprone-*,
  performance-*,
  modernize-*,
  readability-*,
  cppcoreguidelines-*,
  -modernize-use-trailing-return-type,
  -readability-magic-numbers,
  -readability-identifier-length,
  -cppcoreguidelines-avoid-magic-numbers,
  -cppcoreguidelines-pro-bounds-constant-array-index,
  -cppcoreguidelines-pro-bounds-pointer-arithmetic

WarningsAsErrors: ''
HeaderFilterRegex: 'include/femheat/.*'
FormatStyle: file
...
